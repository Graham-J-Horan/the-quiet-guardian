---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { CONTACT_INFO } from "../config";

const { whatsappNumber } = CONTACT_INFO;
---

<Layout
  title="Thank You | The Quiet Guardian"
  description="Your assessment request has been received. We will reach out within 48 hours."
  noindex={true}
>
  <Nav />

  <main id="main-content" class="pt-40 pb-32">
    <div class="max-w-3xl mx-auto px-8 md:px-12 text-center">
      <!-- Success Icon -->
      <div class="w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-12" style="background: var(--primary-container);">
        <span class="material-symbols-outlined text-5xl" style="color: var(--primary); font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;" aria-hidden="true">check_circle</span>
      </div>

      <h1 class="text-5xl md:text-6xl mb-8" style="font-family: var(--font-headline); color: var(--on-surface);">
        Request Received with <em class="font-light" style="color: var(--primary);">Dignity.</em>
      </h1>

      <p class="text-xl leading-relaxed mb-12" style="color: var(--on-surface-variant);">
        Thank you for entrusting us with your family's history. Your request for a professional site assessment has been successfully logged in our archive.
      </p>

      <!-- Next Steps Card -->
      <section class="rounded-2xl p-10 mb-12 text-left shadow-sm border border-outline-variant/10" style="background: var(--surface-container-low);">
        <h2 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: var(--primary);">What happens next?</h2>
        <ul class="space-y-6">
          <li class="flex gap-4">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">event_available</span>
            <div>
              <p class="font-bold text-sm" style="color: var(--on-surface);">Response Window</p>
              <p class="text-sm" style="color: var(--on-surface-variant);">A member of our team will review your location details and contact you within <strong>48 hours</strong> to confirm accessibility.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">payments</span>
            <div>
              <p class="font-bold text-sm" style="color: var(--on-surface);">Assessment Invoice</p>
              <p class="text-sm" style="color: var(--on-surface-variant);">Once confirmed, we will issue a digital invoice for the <strong>€45 professional assessment fee</strong> to secure your site visit.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">history_edu</span>
            <div>
              <p class="font-bold text-sm" style="color: var(--on-surface);">Condition Report</p>
              <p class="text-sm" style="color: var(--on-surface-variant);">After the visit, you will receive a comprehensive report with high-resolution photography and a detailed restoration proposal.</p>
            </div>
          </li>
        </ul>
      </section>

      <div class="flex flex-wrap justify-center gap-6">
        <a href="/" class="btn-secondary">Return Home</a>
        <a 
          href={`https://wa.me/${whatsappNumber}`} 
          class="btn-primary" 
          style="background: #25D366; box-shadow: none;"
          target="_blank"
          rel="noopener noreferrer"
        >
          Need urgent help? WhatsApp Us
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
