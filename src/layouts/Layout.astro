---
import "../styles/global.css";
import { CONTACT_INFO } from "../config";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  preloadImage?: string;
}

const title =
  Astro.props.title ?? "The Quiet Guardian | Digital Preservation with Dignity";
const description =
  Astro.props.description ??
  "Meticulous, hand-crafted maintenance and restoration services for memorial sites. A silent steward for your family's history.";
const noindex = Astro.props.noindex ?? false;
const preloadImage = Astro.props.preloadImage;

const { phoneNumber, whatsappNumber } = CONTACT_INFO;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const siteUrl =
  import.meta.env.PUBLIC_SITE_URL ??
  Astro.site?.origin ??
  "https://quiet-guardian.com";
const ogImageUrl = `${siteUrl}/og-image.jpg`;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "The Quiet Guardian",
  image: ogImageUrl,
  description:
    "Meticulous, hand-crafted maintenance and restoration services for memorial sites. A silent steward for your family's history.",
  url: siteUrl,
  telephone: phoneNumber,
  priceRange: "€€",
  address: {
    "@type": "PostalAddress",
    streetAddress: "3 Belgard Road, Newlands, Clondalin",
    postalCode: "Dublin 22",
    addressLocality: "Dublin",
    addressCountry: "IE",
  },
  areaServed: [
    {
      "@type": "AdministrativeArea",
      name: "Leinster",
    },
    {
      "@type": "AdministrativeArea",
      name: "Dublin",
    },
    {
      "@type": "AdministrativeArea",
      name: "Wicklow",
    },
    {
      "@type": "AdministrativeArea",
      name: "Kildare",
    },
    {
      "@type": "AdministrativeArea",
      name: "Meath",
    },
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Memorial Care Services",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Bronze: The Seasonal Refresh",
          description: "Gentle surface cleaning and maintenance.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Silver: The Deep Restoration",
          description: "Comprehensive biological cleaning and restoration.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Gold: The Annual Care",
          description: "Ongoing annual stewardship and quarterly maintenance.",
        },
      },
    ],
  },
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fcf9f5" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {preloadImage && <link rel="preload" as="image" href={preloadImage} />}

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_IE" />
    <meta property="og:site_name" content="The Quiet Guardian" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageUrl} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <!-- Analytics -->
    {
      plausibleDomain && (
        <script
          defer
          data-domain={plausibleDomain}
          src="https://plausible.io/js/script.js"
        />
      )
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,300;1,6..72,400;1,6..72,500&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,300;1,6..72,400;1,6..72,500&family=Manrope:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
      />
      <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />

    <!-- Floating Action Buttons -->
    <div class="fixed bottom-8 right-8 z-50 flex flex-col gap-4">
      <!-- WhatsApp FAB -->
      <a
        href={`https://wa.me/${whatsappNumber}?text=Hi,%20I'm%20interested%20in%20a%20professional%20condition%20assessment%20for%20a%20memorial%20site.`}
        target="_blank"
        rel="noopener noreferrer"
        class="w-14 h-14 rounded-full flex items-center justify-center shadow-2xl hover:scale-105 transition-transform duration-300 group relative"
        style="background: #25D366; color: white;"
        aria-label="Contact us on WhatsApp"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
          ></path></svg
        >
        <span
          class="absolute right-16 px-4 py-2 rounded text-xs font-bold uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap shadow-xl pointer-events-none"
          style="background: var(--on-surface); color: var(--surface);"
        >
          WhatsApp Us
        </span>
      </a>

      <!-- Request Care FAB -->
      <a
        href="/request-care"
        class="w-14 h-14 rounded-full stone-gradient flex items-center justify-center shadow-2xl hover:scale-105 transition-transform duration-300 group relative"
        style="color: var(--on-primary);"
        aria-label="Request Care — quick contact"
      >
        <span class="material-symbols-outlined" aria-hidden="true"
          >edit_note</span
        >
        <span
          class="absolute right-16 px-4 py-2 rounded text-xs font-bold uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap shadow-xl pointer-events-none"
          style="background: var(--on-surface); color: var(--surface);"
        >
          Request Care
        </span>
      </a>
    </div>

    <script>
      // Scroll reveal
      const isReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              if (isReducedMotion) {
                el.classList.add("visible");
              } else {
                const delay = el.dataset.delay ? parseInt(el.dataset.delay) : 0;
                setTimeout(() => el.classList.add("visible"), delay);
              }
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.1 },
      );
      document
        .querySelectorAll(".reveal")
        .forEach((el) => observer.observe(el));

      // Active nav link
      const path = window.location.pathname;
      document.querySelectorAll("[data-nav-link]").forEach((link) => {
        const href = link.getAttribute("href") ?? "";
        if (path === href || (href !== "/" && path.startsWith(href))) {
          link.setAttribute("aria-current", "page");
          link.classList.add("nav-active");
        }
      });
    </script>
  </body>
</html>
