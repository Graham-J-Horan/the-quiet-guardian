---
import { Image } from "astro:assets";
import mainLogo from "../assets/main_logo.jpg";
---

<nav
  id="main-nav"
  class="fixed top-0 w-full z-50 transition-all duration-500"
  aria-label="Primary navigation"
  style="background: rgba(252,249,245,0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);"
>
  <div
    class="flex justify-between items-center px-8 md:px-12 py-5 max-w-screen-2xl mx-auto"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-3 text-xl font-serif tracking-tight group"
      style="color: var(--on-surface); font-family: var(--font-headline);"
      aria-label="The Quiet Guardian — home"
    >
      <div
        class="w-10 h-10 rounded-full overflow-hidden shrink-0 shadow-sm border border-primary/10 transition-transform duration-300 group-hover:scale-105"
      >
        <Image
          src={mainLogo}
          alt=""
          class="w-full h-full object-cover scale-[1.15]"
          loading="eager"
          style="mix-blend-mode: multiply;"
        />
      </div>
      The Quiet Guardian
    </a>

    <!-- Desktop links -->
    <ul
      class="hidden md:flex items-center gap-10 list-none p-0 m-0"
      role="list"
    >
      {
        [
          { href: "/", label: "Home" },
          { href: "/process", label: "Our Services" },
          { href: "/portfolio", label: "Portfolio" },
          { href: "/request-care", label: "Request Care" },
        ].map(({ href, label }) => (
          <li>
            <a
              href={href}
              data-nav-link
              class="nav-link text-sm tracking-wide transition-colors duration-300 block"
              style={`font-family: var(--font-headline); font-style: italic; color: var(--on-surface-variant);`}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA -->
    <a
      href="/request-care"
      class="btn-primary hidden md:inline-flex"
      style="padding: 0.6rem 1.4rem; font-size: 0.875rem;"
    >
      Contact Us
    </a>

    <!-- Mobile menu button -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
    >
      <span class="block w-5 h-px" style="background: var(--on-surface);"
      ></span>
      <span class="block w-5 h-px" style="background: var(--on-surface);"
      ></span>
      <span class="block w-5 h-px" style="background: var(--on-surface);"
      ></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden px-8 pb-6">
    <ul class="flex flex-col gap-4 list-none p-0 m-0">
      {
        [
          { href: "/", label: "Home" },
          { href: "/process", label: "Our Services" },
          { href: "/portfolio", label: "Portfolio" },
          { href: "/request-care", label: "Request Care" },
        ].map(({ href, label }) => (
          <li>
            <a
              data-nav-link
              href={href}
              class="py-2 text-sm block"
              style="color: var(--on-surface-variant); font-family: var(--font-headline); font-style: italic;"
            >
              {label}
            </a>
          </li>
        ))
      }
      <li>
        <a href="/request-care" class="btn-primary mt-2 flex justify-center">
          Contact Us
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav-link:hover {
    color: var(--primary) !important;
  }
  .nav-link[aria-current="page"],
  .nav-active {
    color: var(--primary) !important;
    border-bottom: 1.5px solid var(--primary);
    padding-bottom: 2px;
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute(
      "aria-label",
      open ? "Close navigation menu" : "Open navigation menu",
    );
  });

  // Scroll shadow
  const nav = document.getElementById("main-nav");
  window.addEventListener(
    "scroll",
    () => {
      if (window.scrollY > 20) {
        nav?.style.setProperty("box-shadow", "0 1px 24px rgba(50,51,47,0.06)");
      } else {
        nav?.style.setProperty("box-shadow", "none");
      }
    },
    { passive: true },
  );
</script>
